# deps
node_modules/

# build outputs
dist/
*.tsbuildinfo
.mcpb-build/

# coverage reports
coverage/

# logs
*.log
npm-debug.log*

# env / local config
.env
.env.local
.env.*.local

# OS junk
.DS_Store
Thumbs.db

# editor
.vscode/
.idea/

# claude code local-only settings
.claude/settings.local.json

# harness outputs — contain vault-specific data (paths, note names, person names)
# never commit these; share reports manually if needed
reports/
out/
tmp/
*.tmp

# write-safety scratch vaults (defensive — must never be committed)
safety-scratch/

# benchmark corpus raw text — public-domain PG EB1911 volumes, fetched on demand
# via `npm run harness -- fetch-corpus` and verified against corpus/manifest.json.
# The generated vault under fixtures/vault/ is the committed canonical artifact;
# the raw corpus is large and regenerable, so it stays out of git.
packages/harness/fixtures/corpus/raw/

# claude code local task state
.claude/scheduled_tasks.lock
seekstone.mcpb

# mcp-publisher binary downloaded by CI release workflow
mcp-publisher

# Fixture vaults commit only `.obsidian/.gitkeep` (enough for filesystem-direct
# servers to recognize the vault). Ignore everything else Obsidian writes into
# `.obsidian/` when a vault is opened — workspace layout, enabled-plugin list,
# and plugin data INCLUDING the Local REST API key — so it can never be
# committed and never shows up as churn.
packages/harness/fixtures/*/.obsidian/**
!packages/harness/fixtures/*/.obsidian/.gitkeep

# Stray notes Obsidian creates in a fixture vault during manual captures.
packages/harness/fixtures/**/Untitled*
packages/harness/fixtures/**/*.base
